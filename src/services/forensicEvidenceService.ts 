import { withTx } from '../db/tx';
import { ForensicEventRepository } from '../repositories/forensicEventRepository';
import { MutationLedgerRepository } from '../repositories/mutationLedgerRepository';
import { ProductJournalRepository } from '../repositories/productJournalRepository';
import { PhaseSummaryRepository } from '../repositories/phaseSummaryRepository';

export interface RecordForensicEvidenceInput {
  processRunId: string;
  processStepId?: number | null;
  entityType: string;
  entityPk: string;
  eventType: string;
  actionType: string;
  sourceTable?: string | null;
  sourcePk?: string | null;
  queueName?: string | null;
  jobId?: string | null;
  correlationId?: string | null;
  causationId?: string | null;
  idempotencyKey?: string | null;
  actorType?: 'user' | 'worker' | 'system' | 'api' | 'service_account';
  actorId?: string | null;
  actorName?: string | null;
  workerName?: string | null;
  workerInstanceId?: string | null;
  beforeJson?: Record<string, unknown> | null;
  afterJson?: Record<string, unknown> | null;
  evidenceJson?: Record<string, unknown>;
  metricsJson?: Record<string, unknown>;
  flagsJson?: unknown[];
  mutation?: {
    tableName: string;
    rowPk: string;
    operationType: 'INSERT' | 'UPDATE' | 'UPSERT' | 'DELETE';
    changedFields?: string[];
    changeSummary?: Record<string, unknown>;
  } | null;
  journal?: {
    eventType: string;
    processName: string;
    processStage?: string | null;
    listingId?: string | null;
    candidateId?: number | null;
    watchlistId?: number | null;
    sourceListingNormalizedId?: number | null;
    decisionCode?: string | null;
    reasonCodes?: string[];
    riskFlags?: string[];
    eventSummary: string;
    eventDetailsJson?: Record<string, unknown>;
  } | null;
  summary?: {
    processName: string;
    processStage?: string | null;
    listingId?: string | null;
    candidateId?: number | null;
    watchlistId?: number | null;
    summaryLine: string;
    summaryOrder?: number;
  } | null;
}

export class ForensicEvidenceService {
  async record(input: RecordForensicEvidenceInput) {
    return withTx(async (client) => {
      const forensicRepo = new ForensicEventRepository(client);
      const mutationRepo = new MutationLedgerRepository(client);
      const journalRepo = new ProductJournalRepository(client);
      const summaryRepo = new PhaseSummaryRepository(client);

      const event = await forensicRepo.append({
        processRunId: input.processRunId,
        processStepId: input.processStepId ?? null,
        correlationId: input.correlationId ?? null,
        causationId: input.causationId ?? null,
        entityType: input.entityType,
        entityPk: input.entityPk,
        eventType: input.eventType,
        actionType: input.actionType,
        actorType: input.actorType ?? 'worker',
        actorId: input.actorId ?? input.workerName ?? null,
        actorName: input.actorName ?? input.workerName ?? null,
        workerName: input.workerName ?? null,
        workerInstanceId: input.workerInstanceId ?? null,
        sourceTable: input.sourceTable ?? null,
        sourcePk: input.sourcePk ?? null,
        queueName: input.queueName ?? null,
        jobId: input.jobId ?? null,
        idempotencyKey: input.idempotencyKey ?? null,
        beforeJson: input.beforeJson ?? {},
        afterJson: input.afterJson ?? {},
        evidenceJson: input.evidenceJson ?? {},
        metricsJson: input.metricsJson ?? {},
        flagsJson: input.flagsJson ?? []
      });

      if (input.mutation) {
        await mutationRepo.append({
          processRunId: input.processRunId,
          correlationId: input.correlationId ?? null,
          tableName: input.mutation.tableName,
          rowPk: input.mutation.rowPk,
          operationType: input.mutation.operationType,
          changedFields: input.mutation.changedFields ?? [],
          changeSummary: {
            forensicEventId: event.id,
            ...(input.mutation.changeSummary ?? {})
          },
          actorType: input.actorType ?? 'worker',
          actorId: input.actorId ?? input.workerName ?? null,
          workerName: input.workerName ?? null,
          workerInstanceId: input.workerInstanceId ?? null
        });
      }

      if (input.journal) {
        await journalRepo.append({
          entityType: input.entityType,
          entityPk: input.entityPk,
          listingId: input.journal.listingId ?? null,
          candidateId: input.journal.candidateId ?? null,
          watchlistId: input.journal.watchlistId ?? null,
          sourceListingNormalizedId: input.journal.sourceListingNormalizedId ?? null,
          eventType: input.journal.eventType,
          processName: input.journal.processName,
          processStage: input.journal.processStage ?? null,
          processRunId: input.processRunId,
          correlationId: input.correlationId ?? null,
          actorType: input.actorType ?? 'worker',
          actorId: input.actorId ?? input.workerName ?? null,
          actorName: input.actorName ?? input.workerName ?? null,
          workerName: input.workerName ?? null,
          workerInstanceId: input.workerInstanceId ?? null,
          decisionCode: input.journal.decisionCode ?? null,
          reasonCodes: input.journal.reasonCodes ?? [],
          riskFlags: input.journal.riskFlags ?? [],
          eventSummary: input.journal.eventSummary,
          eventDetailsJson: {
            forensicEventId: event.id,
            ...(input.journal.eventDetailsJson ?? {})
          }
        });
      }

      if (input.summary) {
        await summaryRepo.append({
          entityType: input.entityType,
          entityPk: input.entityPk,
          listingId: input.summary.listingId ?? null,
          candidateId: input.summary.candidateId ?? null,
          watchlistId: input.summary.watchlistId ?? null,
          processName: input.summary.processName,
          processStage: input.summary.processStage ?? null,
          processRunId: input.processRunId,
          summaryLine: input.summary.summaryLine,
          summaryOrder: input.summary.summaryOrder ?? 0
        });
      }

      return event;
    });
  }

  async getRunEvidence(processRunId: string) {
    return withTx(async (client) => {
      const forensicRepo = new ForensicEventRepository(client);
      return forensicRepo.getByRunId(processRunId);
    });
  }

  async getEntityEvidence(entityType: string, entityPk: string) {
    return withTx(async (client) => {
      const forensicRepo = new ForensicEventRepository(client);
      return forensicRepo.getByEntity(entityType, entityPk);
    });
  }

  async validateHashChain(processRunId: string) {
    const events = await this.getRunEvidence(processRunId);

    let mismatches = 0;

    for (let i = 1; i < events.length; i += 1) {
      const prev = events[i - 1];
      const current = events[i];
      if ((current.prev_hash ?? '') !== (prev.event_hash ?? '')) {
        mismatches += 1;
      }
    }

    return {
      processRunId,
      eventCount: events.length,
      mismatches,
      ok: mismatches === 0
    };
  }
}
