{
  "name": "arb-system-api",
  "version": "1.0.0",
  "private": true,
  "description": "Production eBay arbitrage API, workers, health, metrics, and probe system",
  "main": "dist/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "worker:capital-allocation": "tsx src/workers/capitalAllocationWorker.ts",
    "preflight:capital-allocation": "bash scripts/preflight-capital-allocation.sh",
    "certify:phase2": "jest --runInBand src/tests/certification",
    "certify:report": "ts-node src/scripts/certify.ts",
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:api": "node dist/server.js",
    "start:comp-worker": "node dist/workers/compAnalysisWorker.js",
    "start:retry-worker": "node dist/workers/retryWorker.js",
    "pm2:start": "PATH=./node_modules/.bin:$PATH pm2 start ecosystem.config.cjs",
    "pm2:reload": "PATH=./node_modules/.bin:$PATH pm2 reload ecosystem.config.cjs",
    "pm2:status": "PATH=./node_modules/.bin:$PATH pm2 status",
    "pm2:logs": "PATH=./node_modules/.bin:$PATH pm2 logs",
    "preflight": "PATH=./node_modules/.bin:$PATH bash scripts/preflight-and-probe.sh",
    "start:market-intel-worker": "node dist/workers/marketIntelWorker.js",
    "start:watchlist-worker": "node dist/workers/watchlistWorker.js",
    "start:opportunity-queue-worker": "node dist/workers/opportunityQueueWorker.js",
    "check:deps": "bash scripts/check-deps.sh",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:prong2": "jest src/__tests__/prong2Readiness.test.ts src/__tests__/prong2HealthRoutes.test.ts --runInBand",
    "upgrade:node20": "sudo bash scripts/upgrade-node20-rebuild-refresh.sh",
    "migrate": "tsx src/scripts/migrate.ts",
    "preflight:forensic": "tsx src/scripts/preflight.ts",
    "start:workers": "node dist/src/workers/workerBootstrap.js",
    "dev:workers": "tsx src/workers/workerBootstrap.ts",
    "capital:safety:phase2-hardening": "node dist/workers/phase2HardeningWorker.js",
    "capital:safety:grounding": "node dist/workers/prong2CompSetGroundingWorker.js",
    "capital:safety:validate": "node dist/scripts/validatePhase2GreenTier.js",
    "capital:safety:certify-replay": "node dist/scripts/certifyPhase2Replay.js",
    "usps:smoke": "tsx src/scripts/usps-smoke-test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.100.1",
    "axios": "^1.16.1",
    "bullmq": "^5.73.4",
    "dotenv": "^17.3.1",
    "express": "5.2.1",
    "ioredis": "^5.10.1",
    "p-retry": "^7.1.1",
    "pg": "8.20.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "25.5.0",
    "@types/pg": "8.20.0",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "pm2": "6.0.14",
    "rimraf": "6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "6.0.2"
  }
}
